    /* ── Cases marquee ── */
    function initCases(){
      var track = document.querySelector('.sz-mq-cases-track');
      if(!track || track._szMqDone) return;
      /* direct children that are case cards */
      var cards = Array.from(track.children).filter(function(el){
        return el.tagName === 'DIV' || el.tagName === 'SC-IF';
      });
      if(!cards.length) return;
      /* duplicate 2× for seamless loop */
      cards.forEach(function(el){
        var c = el.cloneNode(true);
        c.setAttribute('aria-hidden','true');
        track.appendChild(c);
      });
      track.style.animation = 'szMqScroll ' + Math.max(30, cards.length * 10) + 's linear infinite';
      /* pause on hover for usability */
      var wrap = document.querySelector('.sz-mq-cases-wrap');
      if(wrap){
        wrap.addEventListener('mouseenter',function(){ track.style.animationPlayState='paused'; });
        wrap.addEventListener('mouseleave',function(){ track.style.animationPlayState='running'; });
