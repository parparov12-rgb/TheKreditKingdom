  <script>
  /* ===== ButtonColorful Animation ===== */
  (function() {
    var CSS = `
      @keyframes szCbShine {
        0% { transform: translateX(-220%) skewX(-18deg); }
        100% { transform: translateX(350%) skewX(-18deg); }
      }
      @keyframes szCbGoldGrad {
        0%, 100% { background-position: 0% 50%; }
        50%       { background-position: 100% 50%; }
      }
      @keyframes szCbGlow {
        0%, 100% { box-shadow: 0 2px 10px rgba(255,221,45,0.15), 0 0 0 0 rgba(255,221,45,0); }
        50%       { box-shadow: 0 4px 20px rgba(255,221,45,0.45), 0 0 30px 4px rgba(255,221,45,0.18); }
      }
      @keyframes szCbOutlineGlow {
        0%, 100% { box-shadow: inset 0 0 0 1px rgba(255,221,45,0.25); }
        50%       { box-shadow: inset 0 0 0 1px rgba(255,221,45,0.7), 0 0 14px 1px rgba(255,221,45,0.15); }
      }
      .sz-cb-base {
        position: relative !important;
        overflow: hidden !important;
      }
      button.sz-cb-accent {
        background: linear-gradient(
          90deg,
          #e8c000 0%, #FFDD2D 25%, #ffe45c 50%, #FFDD2D 75%, #e8c000 100%
        ) !important;
        background-size: 250% auto !important;
        animation: szCbGoldGrad 3s ease-in-out infinite, szCbGlow 3s ease-in-out infinite !important;
        border: none !important;
      }
      button.sz-cb-outline {
        animation: szCbOutlineGlow 2.8s ease-in-out infinite !important;
        border-color: rgba(255,221,45,0.3) !important;
      }
      .sz-cb-shine {
        position: absolute;
        top: -10%;
        left: 0;
        width: 35%;
        height: 120%;
        background: linear-gradient(
          105deg,
          transparent 15%,
          rgba(255,255,255,0.52) 50%,
          transparent 85%
        );
        animation: szCbShine 2.6s ease-in-out infinite;
        pointer-events: none;
        z-index: 9;
      }
    `;

    var styleEl = document.createElement('style');
    styleEl.textContent = CSS;
    document.head.appendChild(styleEl);

    function patchBtn(btn) {
      if (btn.dataset.szCb) return;
      btn.dataset.szCb = '1';
      btn.classList.add('sz-cb-base');

      var bgVar = btn.style.getPropertyValue('--bg') || '';
      var bdVar = btn.style.getPropertyValue('--bd') || '';
      var isAccent  = bgVar.indexOf('tui-accent') !== -1;
      var isOutline = bdVar.indexOf('tui-base-04') !== -1;

      if (isAccent) {
        btn.classList.add('sz-cb-accent');
        // Replace React hover handlers with brightness-based ones
        btn.addEventListener('mouseenter', function() {
          if (!btn.disabled) btn.style.filter = 'brightness(1.07)';
        }, true);
        btn.addEventListener('mouseleave', function() {
          btn.style.filter = '';
        }, true);
        btn.addEventListener('mousedown', function() {
          if (!btn.disabled) btn.style.filter = 'brightness(0.93)';
        }, true);
        btn.addEventListener('mouseup', function() {
          btn.style.filter = '';
        }, true);
      } else if (isOutline) {
        btn.classList.add('sz-cb-outline');
      }

      var shine = document.createElement('span');
      shine.className = 'sz-cb-shine';
      shine.style.animationDelay = '-' + (Math.random() * 2.6).toFixed(2) + 's';
      btn.appendChild(shine);
    }

    function scan() {
      document.querySelectorAll('button').forEach(patchBtn);
    }

    var obs = new MutationObserver(function() { scan(); });
    obs.observe(document.documentElement, { childList: true, subtree: true });

    [200, 600, 1500, 3000].forEach(function(t) { setTimeout(scan, t); });
  })();
  </script>

